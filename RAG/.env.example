# =============================================================
# RAG System — Environment Configuration
# Copy to .env and adjust values
# =============================================================

# === Database (PostgreSQL + pgvector) ===
RAG_DB_USER=rag
RAG_DB_PASSWORD=ragpass
RAG_DB_NAME=rag
RAG_DB_HOST=rag-postgres
RAG_DB_PORT=5432
# Full URL (constructed from above, override if needed)
RAG_DATABASE_URL=postgresql://${RAG_DB_USER}:${RAG_DB_PASSWORD}@${RAG_DB_HOST}:${RAG_DB_PORT}/${RAG_DB_NAME}

# === Redis ===
REDIS_URL=redis://rag-redis:6379/0

# === AI Services (Mac Studio — adjust IP) ===
OLLAMA_URL=http://192.168.1.100:11434
WHISPER_URL=http://192.168.1.100:8002

# === Models ===
LLM_MODEL=qwen3:latest
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768
JUDGE_MODEL=qwen3:0.6b

# === Document Processing (Docling) ===
DOCLING_OCR_ENABLED=true
DOCLING_OCR_ENGINE=easyocr
DOCLING_MAX_PAGES=500

# === Chunking ===
CHUNK_SIZE=512
CHUNK_OVERLAP=102
MAX_CHUNK_SIZE=1024
MIN_CHUNK_SIZE=64

# === Retrieval ===
RETRIEVAL_TOP_K=10
SEMANTIC_WEIGHT=0.7
BM25_WEIGHT=0.3

# === Auth ===
JWT_SECRET=change-me-to-random-secret-min-32-chars
JWT_EXPIRY_HOURS=24

# === Web Crawling (mdream) ===
CRAWL_MDREAM_IMAGE=harlanzw/mdream:latest
CRAWL_MAX_DEPTH=3
CRAWL_DRIVER=fetch
CRAWL_MAX_PAGES=100

# === LangFuse ===
LANGFUSE_HOST=http://rag-langfuse:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_DB_NAME=langfuse
LANGFUSE_NEXTAUTH_SECRET=changeme-langfuse-secret
LANGFUSE_SALT=changeme-langfuse-salt

# === Watch Folder ===
WATCH_FOLDER_PATH=/data/watch
WATCH_FOLDER_ENABLED=true

# === Limits ===
MAX_FILE_SIZE_MB=500

# === Backup ===
BACKUP_SCHEDULE=0 3 * * *
BACKUP_PATH=/backups

# === App ===
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
APP_LOG_LEVEL=info
APP_UPLOAD_PATH=/data/uploads
