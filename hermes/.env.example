# LLM provider keys (optional — Hermes prefers Ollama)
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Telegram gateway
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# DB DSNs — use hermes_ro user, NOT root.
# Passwords to be filled after running scripts/create-ro-users.sql on each DB.
PG_N8N_DSN=postgresql://hermes_ro:CHANGEME@host.docker.internal:5432/n8n
PG_RAG_DSN=postgresql://hermes_ro:CHANGEME@host.docker.internal:5434/rag
PG_AGENT_DSN=postgresql://hermes_ro:CHANGEME@host.docker.internal:5436/agent

# Budget
WEEKLY_BUDGET_USD=10

# Cron — legacy jobs (scan-rss, crypto-arbitrage, etc.). Default: off.
HERMES_ENABLE_LEGACY_CRONS=0
