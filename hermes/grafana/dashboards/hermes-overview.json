          "rawSql": "SELECT recorded_at AS time, AVG(people_count) OVER (ORDER BY recorded_at ROWS BETWEEN 5 PRECEDING AND CURRENT ROW) AS avg_3h FROM hermes_pool_occupancy WHERE scrape_ok = true ORDER BY recorded_at",
