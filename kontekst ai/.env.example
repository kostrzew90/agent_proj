# === Database ===
AI_REPO_DB_HOST=localhost
AI_REPO_DB_PORT=5435
AI_REPO_DB_USER=ai_repo
AI_REPO_DB_PASSWORD=ai_repo_pass
AI_REPO_DB_NAME=ai_repo

# === Ollama ===
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_LLM_MODEL=qwen3:8b

# === Anthropic fallback (optional) ===
ANTHROPIC_API_KEY=

# === LLM provider: ollama | anthropic ===
LLM_PROVIDER=ollama

# === API server ===
API_HOST=0.0.0.0
API_PORT=8100

# === Indexing ===
DEFAULT_REPO_PATH=.
DEFAULT_REPO_ID=default

# === Retrieval ===
RETRIEVAL_TOP_K=10
CONTEXT_MAX_TOKENS=4096

# === Plugin permissions ===
PLUGIN_ALLOW_NETWORK=false
PLUGIN_ALLOWLIST=plugin-logs,plugin-template
