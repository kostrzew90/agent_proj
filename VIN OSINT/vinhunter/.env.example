# Database
DATABASE_URL=postgresql+asyncpg://vinhunter:vinhunterpass@vinhunter-db:5432/vinhunter
# Port zewnętrzny: 5436 (n8n=5432, trading=5433, rag=5434, ai-repo=5435, vinhunter=5436)

# Proxy (disabled by default)
PROXY_ENABLED=false
PROXY_LIST=
PROXY_ROTATION=round_robin

# Playwright
PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
PLAYWRIGHT_MAX_CONCURRENT=3

# Plugin timeouts (seconds)
PLUGIN_DEFAULT_TIMEOUT=30
CAPTCHA_TIMEOUT=120

# CORS
CORS_ORIGINS=http://localhost:3010

# API Keys (optional — plugins auto-disable without keys)
AUTOREF_API_KEY=
VINCARIO_API_KEY=
VINCARIO_SECRET_KEY=
UK_MOT_API_KEY=

# Logging
LOG_LEVEL=INFO
